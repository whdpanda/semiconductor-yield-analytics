# ── Data directories ──────────────────────────────────────────────────────────
# Never commit raw datasets, processed artifacts, or train/val/test splits
data/raw/
data/processed/
data/splits/

# Synthetic data is small and reproducible — kept untracked (regenerate on demand)
data/synthetic/

# ── Generated outputs ──────────────────────────────────────────────────────────
# All of outputs/ is generated at runtime — reports, charts, model weights, logs
/outputs/
/reports/

# Top-level model/checkpoint dirs (in case someone saves outside outputs/)
/models/
/checkpoints/

